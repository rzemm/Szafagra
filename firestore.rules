rules_version = '2';

// Wdróż te reguły w Firebase Console:
// https://console.firebase.google.com → Firestore → Rules

service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {

      // Każdy zalogowany (w tym anonimowo) może odczytać dane pokoju
      allow read: if request.auth != null;
      // Tylko właściciel (roomId == uid) może tworzyć/edytować pokój
      allow write: if request.auth.uid == roomId;

      match /playlists/{playlistId} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == roomId;
      }

      match /state/{stateId} {
        allow read: if request.auth != null;
        // Właściciel może pisać wszystko
        allow write: if request.auth.uid == roomId;
        // Gość może tylko zaktualizować SWÓJ głos w voterMap
        allow update: if
          request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voterMap']) &&
          request.resource.data.voterMap
            .diff(resource.data.voterMap)
            .affectedKeys()
            .hasOnly([request.auth.uid]);
      }
    }
  }
}
