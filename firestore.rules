rules_version = '2';

// Deploy these rules in Firebase Console:
// https://console.firebase.google.com -> Firestore -> Rules

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isRoomOwner(roomId) {
      return signedIn() && request.auth.uid == roomId;
    }

    function stateChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyGuestWritableStateFieldsChanged() {
      return stateChangedKeys().hasOnly(['nextVotes', 'skipVoters']);
    }

    function onlyOwnVoteChanged() {
      return request.resource.data.nextVotes
        .diff(resource.data.nextVotes)
        .affectedKeys()
        .hasOnly([request.auth.uid]) &&
        (
          !(request.auth.uid in request.resource.data.nextVotes) ||
          request.resource.data.nextVotes[request.auth.uid] is string
        );
    }

    function onlyOwnSkipVoteChanged() {
      return request.resource.data.skipVoters
        .diff(resource.data.skipVoters)
        .affectedKeys()
        .hasOnly([request.auth.uid]) &&
        (
          !(request.auth.uid in request.resource.data.skipVoters) ||
          request.resource.data.skipVoters[request.auth.uid] == true
        );
    }

    function onlyOwnRatingChanged() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['ratings']) &&
        request.resource.data.ratings.diff(
          resource.data.get('ratings', {})
        ).affectedKeys().hasOnly([request.auth.uid]);
    }

    function guestCanUpdateState() {
      return signedIn() &&
        onlyGuestWritableStateFieldsChanged() &&
        (
          !stateChangedKeys().hasAny(['nextVotes']) ||
          onlyOwnVoteChanged()
        ) &&
        (
          !stateChangedKeys().hasAny(['skipVoters']) ||
          onlyOwnSkipVoteChanged()
        );
    }

    match /tokenIndex/{token} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.data.roomId == request.auth.uid;
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow write: if isRoomOwner(roomId);

      match /playlists/{playlistId} {
        allow read: if signedIn();
        allow write: if isRoomOwner(roomId);
        allow update: if signedIn() && onlyOwnRatingChanged();
      }

      match /state/{stateId} {
        allow read: if signedIn();
        allow write: if isRoomOwner(roomId);
        allow update: if stateId == 'main' && !isRoomOwner(roomId) && guestCanUpdateState();
      }

      match /suggestions/{suggestionId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isRoomOwner(roomId);
      }
    }
  }
}
