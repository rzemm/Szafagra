rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function roomData(roomId) {
      return roomDoc(roomId).data;
    }

    function roomExists(roomId) {
      return exists(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isPrivateRoom(roomId) {
      return roomExists(roomId) && roomData(roomId).type == 'private';
    }

    function isPublicRoom(roomId) {
      return roomExists(roomId) && roomData(roomId).type == 'public';
    }

    function isRoomOwner(roomId) {
      return signedIn() &&
        isPrivateRoom(roomId) &&
        roomData(roomId).ownerId == request.auth.uid;
    }

    function hasPublicAccess(roomId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/publicAccess/$(request.auth.uid)/rooms/$(roomId));
    }

    function canManageRoom(roomId) {
      return isRoomOwner(roomId) || (isPublicRoom(roomId) && hasPublicAccess(roomId));
    }

    function stateChangedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function onlyGuestWritableStateFieldsChanged() {
      return stateChangedKeys().hasOnly(['nextVotes', 'skipVoters']);
    }

    function onlyOwnVoteChanged() {
      return request.resource.data.nextVotes
        .diff(resource.data.nextVotes)
        .affectedKeys()
        .hasOnly([request.auth.uid]) &&
        (
          !(request.auth.uid in request.resource.data.nextVotes) ||
          request.resource.data.nextVotes[request.auth.uid] is string
        );
    }

    function onlyOwnSkipVoteChanged() {
      return request.resource.data.skipVoters
        .diff(resource.data.skipVoters)
        .affectedKeys()
        .hasOnly([request.auth.uid]) &&
        (
          !(request.auth.uid in request.resource.data.skipVoters) ||
          request.resource.data.skipVoters[request.auth.uid] == true
        );
    }

    function onlyOwnRatingChanged() {
      let keys = request.resource.data.diff(resource.data).affectedKeys();
      return keys.hasOnly(['ratings', 'updatedAt']) &&
        request.resource.data.ratings.diff(
          resource.data.get('ratings', {})
        ).affectedKeys().hasOnly([request.auth.uid]);
    }

    function guestCanUpdateState() {
      return signedIn() &&
        onlyGuestWritableStateFieldsChanged() &&
        (
          !stateChangedKeys().hasAny(['nextVotes']) ||
          onlyOwnVoteChanged()
        ) &&
        (
          !stateChangedKeys().hasAny(['skipVoters']) ||
          onlyOwnSkipVoteChanged()
        );
    }

    match /userRooms/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    match /publicAccess/{uid}/rooms/{roomId} {
      allow read: if request.auth.uid == uid;
      allow create, update: if request.auth.uid == uid &&
        isPublicRoom(roomId) &&
        request.resource.data.roomId == roomId;
      allow delete: if request.auth.uid == uid;
    }

    match /tokenIndex/{token} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        roomExists(request.resource.data.roomId) &&
        (
          roomData(request.resource.data.roomId).type == 'public' ||
          roomData(request.resource.data.roomId).ownerId == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        (
          (
            request.resource.data.type == 'private' &&
            request.resource.data.ownerId == request.auth.uid
          ) ||
          (
            request.resource.data.type == 'public' &&
            request.resource.data.ownerId == null
          )
        );
      allow delete: if canManageRoom(roomId);
      allow update: if canManageRoom(roomId) || guestCanUpdateState() || onlyOwnRatingChanged();

      match /suggestions/{suggestionId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if canManageRoom(roomId);
      }
    }
  }
}
